{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "docusaurus.config.js",
    "sidebars.*.js",
    "src/**/*",
    "scripts/**/*",
    "plugins/**/*"
  ],
  "exclude": [
    ".docusaurus",
    "build",
    "node_modules"
  ]
}
